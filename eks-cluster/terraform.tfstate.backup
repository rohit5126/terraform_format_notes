            "json": "{\n  \"Version\": \"2012-10-17\",\n  \"Statement\": [\n    {\n      \"Effect\": \"Allow\",\n      \"Action\": \"sts:AssumeRoleWithWebIdentity\",\n      \"Principal\": {\n        \"Federated\": \"arn:aws:iam::938998270170:oidc-provider/oidc.eks.eu-north-1.amazonaws.com/id/EC2A848BA7DBF7CC288694EFC13CC87B\"\n      },\n      \"Condition\": {\n        \"StringEquals\": {\n          \"oidc.eks.eu-north-1.amazonaws.com/id/EC2A848BA7DBF7CC288694EFC13CC87B:aud\": \"sts.amazonaws.com\",\n          \"oidc.eks.eu-north-1.amazonaws.com/id/EC2A848BA7DBF7CC288694EFC13CC87B:sub\": \"system:serviceaccount:kube-system:ebs-csi-controller-sa\"\n        }\n      }\n    }\n  ]\n}",
